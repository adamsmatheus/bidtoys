# =============================================================
# Variáveis de ambiente obrigatórias para produção
# Copie este arquivo como .env e preencha os valores reais.
# NUNCA commite o .env com valores reais no repositório.
# =============================================================

# Banco de dados PostgreSQL
DB_URL=jdbc:postgresql://seu-host:5432/leilao
DB_USERNAME=seu_usuario
DB_PASSWORD=senha_forte_aqui

# JWT — gere uma chave aleatória de no mínimo 32 caracteres
# Exemplo: openssl rand -base64 64
JWT_SECRET=TROQUE_ISSO_POR_UMA_CHAVE_ALEATORIA_FORTE
JWT_EXPIRATION_MS=86400000

# Redis
REDIS_HOST=seu-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=senha_redis_aqui

# MinIO / S3
MINIO_ENDPOINT=https://seu-minio.exemplo.com
MINIO_ACCESS_KEY=sua_access_key
MINIO_SECRET_KEY=sua_secret_key
MINIO_BUCKET=leilao
MINIO_PUBLIC_URL=https://seu-minio.exemplo.com

# URLs
BASE_URL=https://api.seudominio.com
CORS_ALLOWED_ORIGINS=https://seudominio.com,https://www.seudominio.com

# Upload local (somente se não usar MinIO)
UPLOAD_DIR=/var/app/uploads

# Logging (DEBUG apenas em desenvolvimento)
LOG_LEVEL=INFO
